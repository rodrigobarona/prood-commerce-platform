# ---------------------------------------------------------------------------
# next-commerce — environment variables
# Copy to the repo root as `.env.local`, then run `pnpm env:link` so every app
# symlinks to the shared file. For production, set vars in each Vercel project.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ---------------------------------------------
# Provisioned via the Vercel Neon integration. Used by the platform adapter
# (commerce data) and Better Auth (auth tables) — same database.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# --- Multi-tenant (storefront / dashboard) ---------------------------------
# Default org when host-based tenant resolution is not configured.
DEFAULT_TENANT_ORG_ID="org_demo"

# --- Commerce engine -------------------------------------------------------
# Adapter: platform (built-in Neon engine, default) | medusa | salla
COMMERCE_ADAPTER="platform"
# Default store currency (ISO 4217)
COMMERCE_CURRENCY="EUR"

# --- Storage provider ------------------------------------------------------
# vercel-blob (default) | s3 (AWS S3 / Cloudflare R2 / MinIO)
STORAGE_PROVIDER="vercel-blob"
# Vercel Blob (when STORAGE_PROVIDER=vercel-blob)
BLOB_READ_WRITE_TOKEN=""
# S3 / Cloudflare R2 (when STORAGE_PROVIDER=s3)
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# --- Auth (Better Auth) ----------------------------------------------------
# Generate a secret: openssl rand -base64 32 (required in production)
BETTER_AUTH_SECRET="dev-only-local-secret-change-me-before-production"
# Public base URL of the storefront (used for callbacks + payment return URLs)
BETTER_AUTH_URL="http://localhost:3000"
# Auth provider seam: better-auth (default) | workos | clerk
AUTH_PROVIDER="better-auth"

# --- Payments --------------------------------------------------------------
# Default provider: stripe | easypay | ifthenpay
DEFAULT_PAYMENT_PROVIDER="stripe"

# Stripe (embedded Payment Element)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Easypay (Portugal) — Multibanco / MB WAY / card
EASYPAY_ACCOUNT_ID=""
EASYPAY_API_KEY=""
# Use https://api.test.easypay.pt for sandbox
EASYPAY_BASE_URL="https://api.prod.easypay.pt"

# Ifthenpay (Portugal) — Multibanco / MB WAY / card
IFTHENPAY_ANTIPHISHING_KEY=""
IFTHENPAY_MB_KEY=""
IFTHENPAY_MBWAY_KEY=""
IFTHENPAY_CC_KEY=""

# --- Checkout (apps/checkout) ----------------------------------------------
# URL where the checkout app runs (storefront redirects here)
CHECKOUT_URL="http://localhost:3004"
# Commerce API base (webhooks forward here for tenant-scoped reconciliation)
COMMERCE_API_URL="http://localhost:3005/v1"
# Public URL of the storefront (for return-after-payment redirects)
STOREFRONT_URL="http://localhost:3000"
# Shared secret between storefront and checkout (for API auth)
# Generate: openssl rand -base64 32
CHECKOUT_API_SECRET=""

# --- Upstash Redis (checkout session storage) ------------------------------
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Dashboard (apps/dashboard) --------------------------------------------
# Custom domain provisioning via Vercel API (optional for local dev)
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_TEAM_ID=""
# Apex for tenant storefront subdomains only: {slug}.prood.app
# Platform services on prood.com (marketing + admin + API + checkout + docs):
#   prood.com              marketing site (apps/web)
#   dashboard.prood.com    merchant admin (orders at /orders)
#   api.prood.com          Commerce API
#   pay.prood.com          hosted checkout
#   docs.prood.com         documentation
NEXT_PUBLIC_PLATFORM_DOMAIN="prood.app"

# --- Commerce API (apps/api) -----------------------------------------------
# Server-side base URL for BFF / dashboard / storefront API clients
COMMERCE_API_URL="http://localhost:3005/v1"
# Public origin of apps/api (agent OpenAPI proxy + discovery)
API_PUBLIC_URL="http://localhost:3005"
# Tenant-scoped API key for Agent Auth OpenAPI proxy (metadata: organizationId + scopes)
AGENT_PROXY_API_KEY=""
AGENT_DEVICE_AUTH_PAGE="/device/capabilities"
TRUST_PROXY="false"

# --- Marketing site (apps/web) ---------------------------------------------
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_DOCS_URL="http://localhost:3003"
NEXT_PUBLIC_STOREFRONT_URL="http://localhost:3000"
# Production: https://dashboard.prood.com
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3002"
# Production: https://api.prood.com
NEXT_PUBLIC_API_URL="http://localhost:3005"
