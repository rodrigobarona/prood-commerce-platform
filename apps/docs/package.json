{
  "name": "docs",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "sync:openapi": "tsx scripts/sync-openapi.ts",
    "prebuild": "pnpm sync:openapi",
    "build": "next build",
    "dev": "pnpm sync:openapi && next dev -p 3003",
    "start": "next start -p 3003",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,mdx}\"",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.10",
    "fumadocs-openapi": "^10.9.1",
    "fumadocs-ui": "16.9.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prood/eslint-config": "workspace:^",
    "@prood/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=24"
  }
}
