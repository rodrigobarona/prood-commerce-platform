    "@neondatabase/serverless": "catalog:",
    "@prood/auth": "workspace:*",
    "@prood/billing": "workspace:*",
    "@prood/commerce": "workspace:*",
    "@prood/platform": "workspace:*",
    "@prood/notification-resend": "workspace:*",
    "@prood/types": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "mcp-handler": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@prood/eslint-config": "workspace:^",
    "@prood/typescript-config": "workspace:*",
    "@types/node": "catalog:",
