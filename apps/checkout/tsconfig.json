{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/commerce": ["../../packages/commerce/src/index.ts"],
      "@workspace/commerce/*": ["../../packages/commerce/src/*"],
      "@workspace/checkout-host": ["../../packages/checkout-host/src/index.ts"],
      "@workspace/checkout-host/*": ["../../packages/checkout-host/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
